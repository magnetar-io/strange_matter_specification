{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ComponentSlim",
  "version": "0.91",
  "date": "2025-09-30",
  "description": "Slim schema for Strange Matter components. Contains only minimum required fields; validation constraints and optional metadata are defined in the full schema.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "ComponentType": {
      "type": "string"
    },
    "DataAuthorIdentifier": {
      "type": "string"
    },
    "Context": {
      "type": "string"
    },
    "GraphSequence": {
      "type": "array",
      "items": { "type": "string" }
    },
    "UsedAsA": {
      "type": "string"
    },
    "ComponentClassification": {
      "type": "string"
    },
    "Tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "Status": {
      "type": "string"
    },
    "Extends": {
      "type": "array",
      "items": { "type": "string" }
    },
    "EntityGUID": {
      "type": "string"
    },
    "ComponentGUID": {
      "type": "string"
    },
    "ComponentVersionGUID": {
      "type": "string"
    },
    "ForeignIDs": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "DateCreated": {
      "type": "string"
    },
    "LastModified": {
      "type": "string"
    },
    "Payload": {
      "type": ["array", "null"],
      "items": { "type": "object" }
    }
  },
  "required": [
    "ComponentType",
    "DataAuthorIdentifier",
    "Context",
    "GraphSequence",
    "UsedAsA",
    "ComponentClassification",
    "Status",
    "EntityGUID",
    "ComponentGUID",
    "ComponentVersionGUID",
    "ForeignIDs",
    "DateCreated",
    "LastModified",
    "Payload"
  ]
}
